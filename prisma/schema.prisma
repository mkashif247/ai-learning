generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  name      String?
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roadmaps Roadmap[]
  progress Progress[]
}

enum Role {
  USER
  ADMIN
}

model Roadmap {
  id          String   @id @default(uuid())
  title       String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nodes RoadmapNode[]
}

model RoadmapNode {
  id          String  @id @default(uuid())
  title       String
  description String?
  order       Int
  roadmapId   String
  roadmap     Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  progress Progress[]
}

model Progress {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodeId      String
  node        RoadmapNode    @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  status      ProgressStatus @default(NOT_STARTED)
  completedAt DateTime?

  @@unique([userId, nodeId])
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}
